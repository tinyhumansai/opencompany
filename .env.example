# Copy to .env and edit. Read by `docker compose`.

# ── The switch: which company (module) spins up ─────────────────────────────
# An example directory name under examples/, or a friendly alias.
#   dir names: agentic_marketing_agency, agentic_venture_capital,
#              agentic_software_company, agentic_venture_studio, agentic_law_firm,
#              signals_opportunity_studio, startup_accelerator, … (see examples/)
#   aliases:   marketing, fund, software, studio, law, accelerator, signals, …
OPENCOMPANY_COMPANY=agentic_marketing_agency

# ── Host + console ports ────────────────────────────────────────────────────
OPENCOMPANY_PORT=8080
CONSOLE_PORT=5173

# ── Optional build/runtime toggles ──────────────────────────────────────────
# Cargo features compiled into the host binary (blank = small default build).
#   e.g. "medulla tinyplace sqlite openhuman-rpc"
OPENCOMPANY_FEATURES=
# Go public on tiny.place at boot (needs the tinyplace feature to reach the net).
OPENCOMPANY_DISCOVERABLE=false

# ── Credentials (optional) ──────────────────────────────────────────────────
# Unlocks live Medulla cognition; blank runs the offline demo brain.
TINYHUMANS_API_KEY=
# Only used by the feedback→issue flow.
GITHUB_TOKEN=
# Provider credential used by future live examples.
OPENAI_API_KEY=

# Storage backend: fs (default), sqlite, or mongodb. The mongodb backend is
# the multi-tenant platform option — the hosting layer injects a per-tenant
# database and scoped credentials (see docs/spec/runtime/storage.md).
OPENCOMPANY_STORAGE=fs
OPENCOMPANY_MONGODB_URI=
OPENCOMPANY_MONGODB_DB=
